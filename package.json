{
    "name": "@maxpaulus/changelogger",
    "version": "0.4.0",
    "description": "Generate changelog entries from release commits.",
    "repository": {
        "type": "git",
        "url": "https://github.com/maxpaulus43/changelogger"
    },

    "keywords": [
        "changelog",
        "git",
        "release"
    ],
    "license": "MIT",
    "bin": {
        "changelogger": "./bin/changelogger.mjs"
    },
    "files": [
        "bin/",
        "scripts/"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "test": "node --test test/**/*.test.mjs",
        "prepare": "node ./bin/changelogger.mjs install"
    }
}
